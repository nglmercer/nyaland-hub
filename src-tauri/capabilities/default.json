{
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "opener:default",
    "opener:allow-open-path",
    {
      "identifier": "fs:scope",
      "allow": [
        "$APPDATA/**/*",
        "$APPCONFIG/**/*",
        "$APPLOCALDATA/**/*",
        "$APPCACHE/**/*",
        "$APPLOG/**/*",
        "$DOWNLOAD/**/*",
        "$HOME/**/*",
        "$DOCUMENT/**/*",
        "$DESKTOP/**/*",
        "$TEMP/**/*",
        "$PUBLIC/**/*",
        "$RESOURCE/**/*"
      ]
    }
  ]
}
